{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "smartsaas-analytics",
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "/frontend/dashboard.html"
    },
    {
      "source": "/customers",
      "destination": "/frontend/customers.html"
    },
    {
      "source": "/predictor",
      "destination": "/frontend/predictor.html"
    },
    {
      "source": "/explainable-ai",
      "destination": "/frontend/explainable-ai.html"
    },
    {
      "source": "/campaigns",
      "destination": "/frontend/campaigns.html"
    },
    {
      "source": "/reports",
      "destination": "/frontend/reports.html"
    },
    {
      "source": "/settings",
      "destination": "/frontend/settings.html"
    },
    {
      "source": "/login",
      "destination": "/frontend/login.html"
    },
    {
      "source": "/customer-detail",
      "destination": "/frontend/customer-detail.html"
    },
    {
      "source": "/recommendations",
      "destination": "/frontend/recommendations.html"
    },
    {
      "source": "/",
      "destination": "/frontend/dashboard.html"
    }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "env": {
    "API_URL": "https://smartsaas-analytics.onrender.com/api"
  }
}